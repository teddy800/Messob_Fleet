# MESSOB Fleet Management System - Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration (for Render deployment)
# =============================================================================
# Get these values from your Render PostgreSQL database info page
HOST=your-postgres-hostname.render.com
DB_PORT=5432
USER=messob_user
PASSWORD=your-database-password
DB_NAME=messob_fleet

# =============================================================================
# Odoo Configuration
# =============================================================================
PORT=8069
ADMIN_PASSWORD=change-this-to-strong-password

# =============================================================================
# Frontend Configuration
# =============================================================================
# For frontend/.env file
VITE_API_BASE_URL=https://your-backend-url.onrender.com
VITE_WS_URL=wss://your-backend-url.onrender.com/ws
