# MESSOB Fleet Management System - Frontend Environment Configuration
# PRODUCTION DEPLOYMENT TEMPLATE
# 
# Copy this file to .env and update with your production values

# =============================================================================
# API Configuration (REQUIRED - UPDATE THESE!)
# =============================================================================
# Backend API Base URL - Your Render backend URL
VITE_API_BASE_URL=https://messob-fleet.onrender.com

# WebSocket URL for real-time GPS tracking
VITE_WS_URL=wss://messob-fleet.onrender.com/ws

# =============================================================================
# Application Settings
# =============================================================================
VITE_APP_TITLE=MESSOB Fleet Management
VITE_APP_VERSION=1.1.1
VITE_APP_ENV=production

# =============================================================================
# Feature Flags
# =============================================================================
VITE_ENABLE_GPS_TRACKING=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_MAINTENANCE_ALERTS=true
VITE_ENABLE_ANALYTICS=true

# =============================================================================
# Map Configuration
# =============================================================================
VITE_MAP_PROVIDER=openstreetmap
VITE_MAP_DEFAULT_LAT=9.0320
VITE_MAP_DEFAULT_LNG=38.7469
VITE_MAP_DEFAULT_ZOOM=12

# =============================================================================
# Production Settings
# =============================================================================
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=error
VITE_ENFORCE_HTTPS=true
VITE_SESSION_TIMEOUT=30
