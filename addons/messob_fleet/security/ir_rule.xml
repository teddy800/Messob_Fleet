<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Trip Request Rules
        ============================================================ -->

        <!-- Standard users see only their own requests -->
        <record id="rule_messob_trip_request_personal" model="ir.rule">
            <field name="name">Trip Requests: Personal (Staff)</field>
            <field name="model_id" ref="model_messob_trip_request"/>
            <field name="domain_force">[('requester_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Dispatchers see all requests -->
        <record id="rule_messob_trip_request_all" model="ir.rule">
            <field name="name">Trip Requests: All (Dispatchers)</field>
            <field name="model_id" ref="model_messob_trip_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_dispatcher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Drivers see only trips assigned to them -->
        <record id="rule_messob_trip_request_driver" model="ir.rule">
            <field name="name">Trip Requests: Assigned (Drivers)</field>
            <field name="model_id" ref="model_messob_trip_request"/>
            <field name="domain_force">[('assigned_driver_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_driver'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- ============================================================
             GPS Track Rules — users can only read, admins manage
        ============================================================ -->
        <record id="rule_messob_gps_track_user" model="ir.rule">
            <field name="name">GPS Track: Read-only (Users)</field>
            <field name="model_id" ref="model_messob_gps_track"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

    </data>
</odoo>
