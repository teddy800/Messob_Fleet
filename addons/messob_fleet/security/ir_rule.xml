<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule for Standard Users: Can only see their own trip requests -->
        <record id="rule_messob_trip_request_personal" model="ir.rule">
            <field name="name">Personal Trip Requests</field>
            <field name="model_id" ref="model_messob_trip_request"/>
            <field name="domain_force">[('requester_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rule for Dispatchers: Can see all trip requests -->
        <record id="rule_messob_trip_request_all" model="ir.rule">
            <field name="name">All Trip Requests (Dispatchers)</field>
            <field name="model_id" ref="model_messob_trip_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('messob_fleet.group_messob_dispatcher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
