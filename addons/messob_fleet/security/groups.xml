<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FMS User Groups -->
    <record id="group_fms_user" model="res.groups">
        <field name="name">FMS User (Staff)</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Can create and view own trip requests</field>
    </record>
    
    <record id="group_fms_dispatcher" model="res.groups">
        <field name="name">FMS Dispatcher</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_fms_user'))]"/>
        <field name="comment">Can approve requests and assign vehicles</field>
    </record>
    
    <record id="group_fms_admin" model="res.groups">
        <field name="name">FMS Admin</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('group_fms_dispatcher'))]"/>
        <field name="comment">Full system access</field>
    </record>
</odoo>