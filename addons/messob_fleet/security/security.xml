<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_messob_fleet" model="ir.module.category">
            <field name="name">MESSOB Fleet</field>
            <field name="description">Roles for MESSOB Fleet Management</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_messob_user" model="res.groups">
        <!-- users -->
            <field name="name">Standard User (Staff)</field>
            <field name="category_id" ref="module_category_messob_fleet"/>
        </record>

        <record id="group_messob_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_messob_fleet"/>
        </record>

        <record id="group_messob_dispatcher" model="res.groups">
            <field name="name">Dispatcher</field>
            <field name="category_id" ref="module_category_messob_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_messob_user'))]"/>
        </record>

        <record id="group_messob_mechanic" model="res.groups">
            <field name="name">Mechanic</field>
            <field name="category_id" ref="module_category_messob_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_messob_user'))]"/>
        </record>

        <record id="group_messob_admin" model="res.groups">
            <field name="name">Fleet Admin</field>
            <field name="category_id" ref="module_category_messob_fleet"/>
            <field name="implied_ids" eval="[(4, ref('group_messob_dispatcher')), (4, ref('group_messob_mechanic'))]"/>
        </record>
    </data>
</odoo>
