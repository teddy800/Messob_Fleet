<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Cron Job: Retry Failed SMS -->
        <record id="ir_cron_retry_failed_sms" model="ir.cron">
            <field name="name">MESSOB FMS: Retry Failed SMS</field>
            <field name="model_id" ref="model_messob_fms_sms_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_failed_sms()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron Job: Cleanup Old SMS Logs -->
        <record id="ir_cron_cleanup_old_sms_logs" model="ir.cron">
            <field name="name">MESSOB FMS: Cleanup Old SMS Logs</field>
            <field name="model_id" ref="model_messob_fms_sms_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_old_sms_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=2, minute=0, second=0)"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
