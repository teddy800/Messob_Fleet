<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job to automatically complete expired trips every 15 minutes -->
    <record id="cron_auto_complete_expired_trips" model="ir.cron">
        <field name="name">MESSOB FMS: Auto-Complete Expired Trips</field>
        <field name="model_id" ref="model_messob_fms_trip"/>
        <field name="state">code</field>
        <field name="code">model.auto_complete_expired_trips()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
        <field name="priority">5</field>
    </record>
</odoo>