<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron job to clean up old API performance logs (keep last 30 days) -->
    <record id="cron_cleanup_api_performance_logs" model="ir.cron">
        <field name="name">MESSOB FMS: Cleanup Old API Performance Logs</field>
        <field name="model_id" ref="model_messob_fms_api_performance"/>
        <field name="state">code</field>
        <field name="code">model._cron_cleanup_old_logs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
    </record>
</odoo>
