<?xml version="1.0" encoding="utf-8"?>
<!--
    MESSOB Fleet Management System
    Menus: All navigation menu items
    Load order: after all view/action XML files
-->
<odoo>

    <!-- ================================================================
         ROOT MENU — visible to all FMS users
    ================================================================ -->
    <menuitem id="menu_fms_root"
              name="MESSOB FMS"
              sequence="10"
              groups="messob_fleet.group_fms_user,messob_fleet.group_fms_dispatcher,messob_fleet.group_fms_driver"/>

    <!-- ================================================================
         STAFF MENUS
    ================================================================ -->

    <!-- Opens the 4-step wizard to create a new request (FR-1.1) -->
    <menuitem id="menu_fms_new_request"
              name="New Request"
              parent="menu_fms_root"
              action="messob_fleet.action_new_trip_wizard"
              sequence="5"
              groups="messob_fleet.group_fms_user"/>

    <!-- Personal dashboard: shows only the logged-in user's requests (FR-1.2) -->
    <menuitem id="menu_fms_my_trips"
              name="My Requests"
              parent="menu_fms_root"
              action="messob_fleet.action_my_trips"
              sequence="10"
              groups="messob_fleet.group_fms_user"/>

    <!-- ================================================================
         DISPATCHER MENUS
    ================================================================ -->

    <menuitem id="menu_fms_current_requests"
              name="Current Requests"
              parent="menu_fms_root"
              sequence="20"
              groups="messob_fleet.group_fms_dispatcher"/>

    <!-- Pending queue: oldest first (FR-2.1) -->
    <menuitem id="menu_fms_pending_queue"
              name="Pending Queue"
              parent="menu_fms_current_requests"
              action="messob_fleet.action_pending_requests"
              sequence="10"
              groups="messob_fleet.group_fms_dispatcher"/>

    <!-- All requests regardless of state -->
    <menuitem id="menu_fms_all_requests"
              name="All Requests"
              parent="menu_fms_current_requests"
              action="messob_fleet.action_all_requests"
              sequence="20"
              groups="messob_fleet.group_fms_dispatcher"/>

    <!-- ================================================================
         DRIVER MENUS
    ================================================================ -->

    <menuitem id="menu_fms_driver_trips"
              name="My Trips"
              parent="menu_fms_root"
              action="messob_fleet.action_driver_my_trips"
              sequence="30"
              groups="messob_fleet.group_fms_driver"/>

    <!-- ================================================================
         ADMIN MENUS (Phase 2 — uncomment when admin views are built)
    ================================================================ -->
