<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for My Requests -->
    <record id="action_messob_trip_request" model="ir.actions.act_window">
        <field name="name">My Trip Requests</field>
        <field name="res_model">messob.trip.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('requester_id','=',uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No trip requests yet. Click "New Request" to create one.
            </p>
        </field>
    </record>

    <!-- List view (formerly "tree") -->
    <record id="view_messob_trip_request_list" model="ir.ui.view">
        <field name="name">messob.trip.request.list</field>
        <field name="model">messob.trip.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Request ID"/>
                <field name="start_datetime" string="Start"/>
                <field name="end_datetime" string="End"/>
                <field name="pickup_location" string="Pickup"/>
                <field name="destination_location" string="Destination"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_messob_trip_request_form" model="ir.ui.view">
        <field name="name">messob.trip.request.form</field>
        <field name="model">messob.trip.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" invisible="state != 'draft'" class="btn-primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="requester_id" readonly="1"/>
                        <field name="purpose"/>
                        <field name="category_id"/>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="pickup_location"/>
                        <field name="destination_location"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>