<?xml version="1.0" encoding="utf-8"?>
<!--
    MESSOB Fleet Management System
    View: Dispatcher Views
    Covers: Module 2 (SRS §3.2) — Pending queue, approval form, all requests
-->
<odoo>

    <!-- DISPATCHER: Pending Queue List View (FR-2.1) -->
    <record id="view_trip_list_dispatcher" model="ir.ui.view">
        <field name="name">messob.fms.trip.list.dispatcher</field>
        <field name="model">messob.fms.trip</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Pending Requests Queue"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  default_order="create_date asc">
                <field name="name"             string="Request ID"   readonly="1"/>
                <field name="requester_id"     string="Requester"    readonly="1"/>
                <field name="state"            string="Status"       widget="badge" readonly="1"/>
                <field name="vehicle_category" string="Vehicle Type" readonly="1"/>
                <field name="purpose"          string="Description"  readonly="1" optional="show"/>
                <field name="start_dt"         string="Start"        widget="datetime" readonly="1"/>
                <field name="end_dt"           string="End"          widget="datetime" readonly="1"/>
                <field name="pickup"           string="From"         readonly="1"/>
                <field name="destination"      string="To"           readonly="1"/>
            </list>
        </field>
    </record>

    <!-- DISPATCHER: Approve Trip Form View (FR-2.2) -->
    <record id="view_trip_form_dispatcher" model="ir.ui.view">
        <field name="name">messob.fms.trip.form.dispatcher</field>
        <field name="model">messob.fms.trip</field>
        <field name="mode">primary</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Approve Trip Request">
                <header>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'pending'"
                            confirm="Approve this trip request?"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'pending'"
                            confirm="Reject this trip request?"/>
                    <button name="action_close"
                            string="Close Trip"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'completed'"
                            confirm="Close this completed trip? This is the final state."/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="pending,approved,rejected,in_progress,completed,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Request"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <!-- Request Info (read-only for dispatcher) -->
                    <group string="Request Information" col="2">
                        <group>
                            <field name="requester_id"     readonly="1"/>
                            <field name="vehicle_category" readonly="1"/>
                            <field name="duration_display" readonly="1" string="Duration"/>
                        </group>
                        <group>
                            <field name="purpose"  readonly="1" widget="text"/>
                            <field name="start_dt" readonly="1" widget="datetime"/>
                            <field name="end_dt"   readonly="1" widget="datetime"/>
                        </group>
                    </group>
                    <!-- Route -->
                    <group string="Trip Route" col="2">
                        <field name="pickup"      readonly="1" string="From"/>
                        <field name="destination" readonly="1" string="To"/>
                    </group>
                    <!-- Resource Assignment (FR-2.2) -->
                    <group string="Resource Assignment" col="2"
                           invisible="state not in ('pending', 'approved')">
                        <field name="assigned_vehicle_id"
                               string="Assign Vehicle"
                               options="{'no_create': True}"
                               placeholder="Select an available vehicle..."/>
                        <field name="assigned_driver_id"
                               string="Assign Driver"
                               options="{'no_create': True}"
                               placeholder="Select an available driver..."/>
                        <field name="fuel_status" string="Fuel Level"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- DISPATCHER: Pending Queue Action (FR-2.1) -->
    <record id="action_pending_requests" model="ir.actions.act_window">
        <field name="name">Pending Requests Queue</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_trip_list_dispatcher')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_trip_form_dispatcher')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No pending requests.</p>
            <p>All requests have been processed.</p>
        </field>
    </record>

    <!-- DISPATCHER: All Requests Action -->
    <record id="action_all_requests" model="ir.actions.act_window">
        <field name="name">All Trip Requests</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_trip_list_dispatcher')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_trip_form_dispatcher')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No trip requests found.</p>
        </field>
    </record>

</odoo>
