<?xml version="1.0" encoding="utf-8"?>
<!--
    MESSOB Fleet Management System
    View: Staff Trip Request Views (Module 1 — FR-1.1, FR-1.2, FR-1.3)

    Dashboard layout (matches wireframe):
      Left sidebar  → MESSOB logo | New Request button | My Requests | Profile
      Main area     → List of own requests (color-coded by status)
      Form view     → Full request detail with Submit / Cancel actions
-->
<odoo>

    <!-- ================================================================
         STAFF: My Requests — List View (FR-1.2)
         Columns match wireframe table:
           Request ID | Purpose | Vehicle | Start | End | From | To | Status
    ================================================================ -->
    <record id="view_trip_list_staff" model="ir.ui.view">
        <field name="name">messob.fms.trip.list.staff</field>
        <field name="model">messob.fms.trip</field>
        <field name="arch" type="xml">
            <list string="My Trip Requests"
                  decoration-muted="state == 'draft'"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-info="state == 'in_progress'"
                  create="false">

                <field name="name"             string="Request ID"/>
                <field name="purpose"          string="Purpose"      optional="show"/>
                <field name="vehicle_category" string="Vehicle"      widget="badge"/>
                <field name="start_dt"         string="Start Date"   widget="datetime"/>
                <field name="end_dt"           string="End Date"     widget="datetime"/>
                <field name="pickup"           string="Start Place"  optional="show"/>
                <field name="destination"      string="Destination"  optional="show"/>
                <field name="state"            string="Status"       widget="badge"/>

            </list>
        </field>
    </record>

    <!-- ================================================================
         STAFF: Trip Request — Form View
         Matches wireframe: two-column layout, status bar at top,
         Submit / Cancel buttons, assignment panel visible after approval.
    ================================================================ -->
    <record id="view_trip_form_staff" model="ir.ui.view">
        <field name="name">messob.fms.trip.form.staff</field>
        <field name="model">messob.fms.trip</field>
        <field name="arch" type="xml">
            <form string="Trip Request">

                <header>
                    <button name="action_submit"
                            string="Submit Request"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Submit this request to the dispatcher?"/>

                    <button name="action_cancel"
                            string="Cancel Request"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'pending'"
                            confirm="Cancel this pending request?"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,pending,approved,rejected,in_progress,completed"/>
                </header>

                <sheet>

                    <!-- Request ID title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ── Two-column layout ── -->
                    <div class="o_row">

                        <!-- LEFT: request details -->
                        <group string="Trip Details" class="col-6">
                            <field name="requester_id"     readonly="1"/>
                            <field name="purpose"          widget="text"
                                   placeholder="Describe the official purpose (min. 10 chars)…"/>
                            <field name="vehicle_category" string="Vehicle Category"/>
                        </group>

                        <!-- RIGHT: schedule + route -->
                        <group string="Schedule &amp; Route" class="col-6">
                            <field name="start_dt"    widget="datetime" string="Starting Date"/>
                            <field name="end_dt"      widget="datetime" string="End Day"/>
                            <field name="pickup"      string="Start Place"
                                   placeholder="e.g., MESSOB HQ"/>
                            <field name="destination" string="Destination Place"
                                   placeholder="e.g., Bole Branch"/>
                            <field name="duration_display" readonly="1" string="Duration"/>
                        </group>

                    </div>

                    <!-- ── Dispatcher assignment (read-only, shown after approval) ── -->
                    <group string="Dispatcher Assignment"
                           invisible="state not in ('approved','in_progress','completed','closed')">
                        <group>
                            <field name="assigned_vehicle_id" readonly="1" string="Assigned Vehicle"/>
                            <field name="assigned_driver_id"  readonly="1" string="Assigned Driver"/>
                        </group>
                        <group>
                            <field name="fuel_status" readonly="1" string="Fuel Status"/>
                        </group>
                    </group>

                </sheet>

                <!-- Full status change history in chatter -->
                <chatter/>

            </form>
        </field>
    </record>

    <!-- ================================================================
         STAFF: My Requests — Window Action (FR-1.2)
         Domain: only the logged-in user's own requests.
    ================================================================ -->
    <record id="action_my_trips" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('requester_id.user_ids', 'in', [uid])]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_trip_list_staff')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_trip_form_staff')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No trip requests yet.</p>
            <p>Click <b>New Request</b> in the menu to submit your first vehicle request.</p>
        </field>
    </record>

</odoo>
