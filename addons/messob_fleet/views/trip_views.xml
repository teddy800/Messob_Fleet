<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Minimal List View -->
    <record id="view_trip_list" model="ir.ui.view">
        <field name="name">messob.fms.trip.list</field>
        <field name="model">messob.fms.trip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="purpose"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Minimal Form View -->
    <record id="view_trip_form" model="ir.ui.view">
        <field name="name">messob.fms.trip.form</field>
        <field name="model">messob.fms.trip</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="purpose"/>
                        <field name="vehicle_category"/>
                        <field name="start_dt"/>
                        <field name="end_dt"/>
                        <field name="pickup"/>
                        <field name="destination"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Minimal Action -->
    <record id="action_my_trips" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Minimal Menu -->
    <menuitem id="menu_fms_root" name="MESSOB FMS"/>
    <menuitem id="menu_fms_my_trips" name="My Requests" parent="menu_fms_root" action="action_my_trips"/>
</odoo>