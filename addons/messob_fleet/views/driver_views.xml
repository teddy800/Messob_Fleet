<?xml version="1.0" encoding="utf-8"?>
<!--
    MESSOB Fleet Management System
    View: Driver Views (Phase 2)

    Layout matches wireframe:
      Left sidebar  → MESSOB logo | Requests | Full Change | Profile | Logout
      Main list     → requester | start place | destination | start time | odometer | day | Start button
      Fuel wizard   → Full States popup: station name, Liter, Price, Odometer, Date
-->
<odoo>

    <!-- ================================================================
         DRIVER: Assigned Trips — List View
         Shows trips assigned to the logged-in driver.
         Columns match wireframe exactly.
    ================================================================ -->
    <record id="view_trip_list_driver" model="ir.ui.view">
        <field name="name">messob.fms.trip.list.driver</field>
        <field name="model">messob.fms.trip</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <list string="My Assigned Trips"
                  decoration-success="state == 'approved'"
                  decoration-info="state == 'in_progress'"
                  decoration-muted="state == 'completed'"
                  create="false"
                  delete="false">

                <field name="requester_id"  string="Requester Name"/>
                <field name="pickup"        string="Start Place"/>
                <field name="destination"   string="Destination Place"/>
                <field name="start_dt"      string="Starting Time"  widget="datetime"/>
                <field name="fuel_status"   string="Odoo Matter States" widget="badge"/>
                <field name="start_dt"      string="Day"
                       widget="date"
                       optional="show"/>
                <field name="state"         string="Status" widget="badge" column_invisible="1"/>

                <!-- Start button — visible when approved -->
                <button name="action_depart"
                        string="Start"
                        type="object"
                        icon="fa-play"
                        class="btn-sm btn-success"
                        invisible="state != 'approved'"
                        confirm="Start this trip?"/>

                <!-- Complete button — visible when in progress -->
                <button name="action_complete"
                        string="Complete"
                        type="object"
                        icon="fa-check"
                        class="btn-sm btn-primary"
                        invisible="state != 'in_progress'"
                        confirm="Mark this trip as completed?"/>

                <!-- Fuel log button — visible when in progress -->
                <button name="action_open_fuel_log"
                        string="Full Change"
                        type="object"
                        icon="fa-tint"
                        class="btn-sm btn-warning"
                        invisible="state != 'in_progress'"/>

            </list>
        </field>
    </record>

    <!-- ================================================================
         DRIVER: Trip Detail — Form View
         Read-only trip info + fuel log history + action buttons.
    ================================================================ -->
    <record id="view_trip_form_driver" model="ir.ui.view">
        <field name="name">messob.fms.trip.form.driver</field>
        <field name="model">messob.fms.trip</field>
        <field name="mode">primary</field>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <form string="Trip Details">

                <header>
                    <button name="action_depart"
                            string="Start Trip"
                            type="object"
                            class="btn-success"
                            invisible="state != 'approved'"
                            confirm="Start this trip now?"/>

                    <button name="action_complete"
                            string="Complete Trip"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'in_progress'"
                            confirm="Mark this trip as completed?"/>

                    <button name="action_open_fuel_log"
                            string="Log Fuel Fill"
                            type="object"
                            class="btn-warning"
                            invisible="state != 'in_progress'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="approved,in_progress,completed"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group string="Trip Information" col="2">
                        <group>
                            <field name="requester_id"     readonly="1" string="Requester"/>
                            <field name="vehicle_category" readonly="1"/>
                            <field name="assigned_vehicle_id" readonly="1" string="Vehicle"/>
                        </group>
                        <group>
                            <field name="start_dt"    readonly="1" widget="datetime"/>
                            <field name="end_dt"      readonly="1" widget="datetime"/>
                            <field name="duration_display" readonly="1" string="Duration"/>
                        </group>
                    </group>

                    <group string="Route" col="2">
                        <field name="pickup"      readonly="1" string="Start Place"/>
                        <field name="destination" readonly="1" string="Destination Place"/>
                    </group>

                    <!-- Fuel log history for this trip -->
                    <notebook>
                        <page string="Fuel Logs" name="fuel_logs">
                            <field name="fuel_log_ids" readonly="1">
                                <list string="Fuel Fills" create="false">
                                    <field name="date"         string="Date"/>
                                    <field name="station_name" string="Station"/>
                                    <field name="liters"       string="Liters"/>
                                    <field name="price"        string="Price"/>
                                    <field name="odometer"     string="Odometer (km)"/>
                                    <field name="price_per_liter" string="Price/Liter"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <!-- ================================================================
         FUEL LOG WIZARD — Form View
         Matches wireframe "Full States" popup:
           Full station name | Liter | Price | Odometer | Date
    ================================================================ -->
    <record id="view_fuel_log_wizard_form" model="ir.ui.view">
        <field name="name">messob.fms.fuel.log.wizard.form</field>
        <field name="model">messob.fms.fuel.log.wizard</field>
        <field name="arch" type="xml">
            <form string="Log Fuel Fill">
                <sheet>

                    <!-- Header matches wireframe "Full States" title -->
                    <div class="o_row mb-3">
                        <h3 class="text-center w-100">Full States</h3>
                    </div>

                    <group>
                        <field name="trip_id"      readonly="1" invisible="1"/>
                        <field name="vehicle_info" readonly="1" string="Vehicle"/>
                        <field name="station_name"
                               string="Full Station Name"
                               placeholder="e.g., Total Bole Road"/>
                        <field name="liters"   string="Liter"   widget="float"/>
                        <field name="price"    string="Price"   widget="float"/>
                        <field name="odometer" string="Odometer"/>
                        <field name="date"     string="Date"    widget="date"/>
                    </group>

                </sheet>

                <footer>
                    <button name="action_save_fuel_log"
                            string="Save"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

    <!-- ================================================================
         DRIVER: My Trips — Window Action
         Domain: only trips assigned to the logged-in driver's partner.
    ================================================================ -->
    <record id="action_driver_my_trips" model="ir.actions.act_window">
        <field name="name">My Trips</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
        <!-- No static domain — record rule handles filtering by driver's partner -->
        <field name="domain">[('state', 'in', ['approved', 'in_progress', 'completed'])]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_trip_list_driver')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_trip_form_driver')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No trips assigned yet.</p>
            <p>The dispatcher will assign trips to you.</p>
        </field>
    </record>

</odoo>
