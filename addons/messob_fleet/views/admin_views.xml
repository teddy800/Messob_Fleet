<?xml version="1.0" encoding="utf-8"?>
<!--
    MESSOB Fleet Management System
    View: Admin Panel (FR-5.1, FR-5.2, FR-5.3)

    Screens (from wireframes):
      1. Dashboard    — stats cards + quick actions
      2. User Mgmt    — res.users list
      3. Vehicles     — fleet.vehicle list
      4. Drivers      — messob.fms.driver list
      5. Audit Logs   — messob.fms.audit.log list
      6. Reports      — links to report actions
      7. Profile      — current user's partner form
-->
<odoo>

    <!-- ================================================================
         1. ADMIN DASHBOARD — kanban-style stat cards + quick actions
    ================================================================ -->
    <record id="view_admin_dashboard" model="ir.ui.view">
        <field name="name">messob.fms.admin.dashboard</field>
        <field name="model">messob.fms.trip</field>
        <field name="arch" type="xml">
            <list string="Admin Dashboard" create="false" delete="false"
                  decoration-warning="state=='pending'"
                  decoration-success="state=='approved'"
                  decoration-danger="state=='rejected'">
                <field name="name"         string="Request ID"/>
                <field name="requester_id" string="Requester"/>
                <field name="state"        string="Status"  widget="badge"/>
                <field name="start_dt"     string="Start"   widget="datetime"/>
                <field name="pickup"       string="From"/>
                <field name="destination"  string="To"/>
            </list>
        </field>
    </record>

    <record id="action_admin_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard — All Requests</field>
        <field name="res_model">messob.fms.trip</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_admin_dashboard')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No trip requests yet.</p>
        </field>
    </record>

    <!-- ================================================================
         2. USER MANAGEMENT — res.users list (FR-5.1)
         Columns: ID | Name | Email | Role | Status
    ================================================================ -->
    <record id="view_admin_user_list" model="ir.ui.view">
        <field name="name">messob.fms.admin.user.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="User Management"
                  decoration-muted="not active">
                <field name="id"     string="ID"         readonly="1"/>
                <field name="name"   string="Name"/>
                <field name="login"  string="Email"/>
                <field name="active" string="Status"     widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_admin_users" model="ir.actions.act_window">
        <field name="name">User Management</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_admin_user_list')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No users found.</p>
            <p>Click <b>New</b> to add a user.</p>
        </field>
    </record>

    <!-- ================================================================
         3. VEHICLE MANAGEMENT — fleet.vehicle list (FR-5.2)
         Columns: ID | Plate No | Model | Make | Year | Status | Actions
    ================================================================ -->
    <record id="view_admin_vehicle_list" model="ir.ui.view">
        <field name="name">messob.fms.admin.vehicle.list</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicle Management"
                  decoration-success="state_id.name == 'New'"
                  decoration-muted="active == False">
                <field name="id"              string="ID"       readonly="1"/>
                <field name="license_plate"   string="Plate No"/>
                <field name="model_id"        string="Model"/>
                <field name="driver_id"       string="Driver"   optional="show"/>
                <field name="model_year"      string="Year"/>
                <field name="state_id"        string="Status"   widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_admin_vehicles" model="ir.actions.act_window">
        <field name="name">Vehicle Management</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_admin_vehicle_list')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No vehicles found.</p>
            <p>Click <b>New</b> to add a vehicle.</p>
        </field>
    </record>

    <!-- ================================================================
         4. DRIVER MANAGEMENT — messob.fms.driver list (FR-5.2)
         Columns: ID | Name | License No | Phone | Status | Actions
    ================================================================ -->
    <record id="view_admin_driver_list" model="ir.ui.view">
        <field name="name">messob.fms.admin.driver.list</field>
        <field name="model">messob.fms.driver</field>
        <field name="arch" type="xml">
            <list string="Driver Management"
                  decoration-success="is_active == True"
                  decoration-muted="is_active == False">
                <field name="id"             string="ID"          readonly="1"/>
                <field name="name"           string="Name"/>
                <field name="license_no"     string="License No"/>
                <field name="phone"          string="Phone"/>
                <field name="license_expiry" string="Expiry"      optional="show"/>
                <field name="status"         string="Status"      widget="badge"/>
                <field name="is_active"      string="Active"      widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_admin_driver_form" model="ir.ui.view">
        <field name="name">messob.fms.admin.driver.form</field>
        <field name="model">messob.fms.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <sheet>
                    <group col="2">
                        <field name="name"           string="Full Name"/>
                        <field name="license_no"     string="License No"/>
                        <field name="license_expiry" string="License Expiry"/>
                        <field name="phone"          string="Phone"/>
                        <field name="partner_id"     string="Linked Contact"
                               options="{'no_create': True}"/>
                        <field name="is_active"      string="Active"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" widget="text" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_admin_drivers" model="ir.actions.act_window">
        <field name="name">Driver Management</field>
        <field name="res_model">messob.fms.driver</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_admin_driver_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_admin_driver_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No drivers found.</p>
            <p>Click <b>New</b> to add a driver.</p>
        </field>
    </record>

    <!-- ================================================================
         5. AUDIT LOGS — messob.fms.audit.log (FR-5.3)
         Comprehensive audit trail viewer with advanced filtering
    ================================================================ -->
    
    <!-- Search View with Filters -->
    <record id="view_admin_audit_search" model="ir.ui.view">
        <field name="name">messob.fms.audit.log.search</field>
        <field name="model">messob.fms.audit.log</field>
        <field name="arch" type="xml">
            <search string="Audit Logs">
                <!-- Search Fields -->
                <field name="user_id" string="User"/>
                <field name="action" string="Action"/>
                <field name="resource_model" string="Model"/>
                <field name="resource_display_name" string="Resource"/>
                <field name="description" string="Description"/>
                <field name="ip_address" string="IP Address"/>
                
                <!-- Filters -->
                <filter name="filter_today" string="Today"
                        domain="[('timestamp', '&gt;=', datetime.datetime.now().replace(hour=0, minute=0, second=0))]"/>
                <filter name="filter_week" string="This Week"
                        domain="[('timestamp', '&gt;=', (datetime.datetime.now() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_month" string="This Month"
                        domain="[('timestamp', '&gt;=', (datetime.datetime.now() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                
                <separator/>
                
                <filter name="filter_failed" string="Failed Actions"
                        domain="[('success', '=', False)]"/>
                <filter name="filter_critical" string="Critical"
                        domain="[('severity', '=', 'critical')]"/>
                <filter name="filter_high" string="High Severity"
                        domain="[('severity', '=', 'high')]"/>
                
                <separator/>
                
                <!-- Action Categories -->
                <filter name="filter_auth" string="Authentication"
                        domain="[('action_category', '=', 'authentication')]"/>
                <filter name="filter_business" string="Business Process"
                        domain="[('action_category', '=', 'business_process')]"/>
                <filter name="filter_data" string="Data Management"
                        domain="[('action_category', '=', 'data_management')]"/>
                <filter name="filter_security" string="Security"
                        domain="[('action_category', '=', 'security')]"/>
                <filter name="filter_system" string="System Admin"
                        domain="[('action_category', '=', 'system_admin')]"/>
                
                <separator/>
                
                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                    <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                    <filter name="group_category" string="Category" context="{'group_by': 'action_category'}"/>
                    <filter name="group_severity" string="Severity" context="{'group_by': 'severity'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- List View -->
    <record id="view_admin_audit_list" model="ir.ui.view">
        <field name="name">messob.fms.audit.log.list</field>
        <field name="model">messob.fms.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Logs" create="false" delete="false" edit="false"
                  decoration-danger="success == False"
                  decoration-warning="severity == 'high'"
                  decoration-info="severity == 'critical'">
                <field name="timestamp" string="Timestamp" widget="datetime"/>
                <field name="user_id" string="User"/>
                <field name="action" string="Action" widget="badge"/>
                <field name="action_category" string="Category" optional="show"/>
                <field name="resource_name" string="Resource Type" optional="show"/>
                <field name="resource_display_name" string="Resource" optional="hide"/>
                <field name="description" string="Description"/>
                <field name="severity" string="Severity" widget="badge" 
                       decoration-danger="severity == 'critical'"
                       decoration-warning="severity == 'high'"
                       decoration-info="severity == 'medium'"
                       decoration-muted="severity == 'low'"/>
                <field name="success" string="Status" widget="boolean" optional="show"/>
                <field name="ip_address" string="IP" optional="hide"/>
            </list>
        </field>
    </record>
    
    <!-- Form View (Read-only) -->
    <record id="view_admin_audit_form" model="ir.ui.view">
        <field name="name">messob.fms.audit.log.form</field>
        <field name="model">messob.fms.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="false" delete="false" edit="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_resource" type="object" 
                                class="oe_stat_button" icon="fa-external-link"
                                string="View Resource"
                                invisible="not resource_model or not resource_id"/>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="action_display" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Action Information">
                            <field name="timestamp" widget="datetime"/>
                            <field name="action" widget="badge"/>
                            <field name="action_category" widget="badge"/>
                            <field name="severity" widget="badge"/>
                            <field name="success" widget="boolean"/>
                            <field name="duration_ms" string="Duration (ms)" 
                                   invisible="not duration_ms"/>
                        </group>
                        
                        <group string="User Information">
                            <field name="user_id"/>
                            <field name="session_id" invisible="not session_id"/>
                            <field name="ip_address" invisible="not ip_address"/>
                            <field name="user_agent" invisible="not user_agent"/>
                        </group>
                    </group>
                    
                    <group string="Resource Information" 
                           invisible="not resource_model">
                        <field name="resource_model"/>
                        <field name="resource_name"/>
                        <field name="resource_id"/>
                        <field name="resource_display_name"/>
                    </group>
                    
                    <group string="Description">
                        <field name="description" nolabel="1" widget="text"/>
                    </group>
                    
                    <group string="Error Details" 
                           invisible="success or not error_message">
                        <field name="error_message" nolabel="1" widget="text"/>
                    </group>
                    
                    <notebook>
                        <page string="Change Details" 
                              invisible="not old_values and not new_values">
                            <group>
                                <group string="Old Values">
                                    <field name="old_values" nolabel="1" widget="text"/>
                                </group>
                                <group string="New Values">
                                    <field name="new_values" nolabel="1" widget="text"/>
                                </group>
                            </group>
                            <group string="Changed Fields">
                                <field name="changed_fields" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Pivot View for Analytics -->
    <record id="view_admin_audit_pivot" model="ir.ui.view">
        <field name="name">messob.fms.audit.log.pivot</field>
        <field name="model">messob.fms.audit.log</field>
        <field name="arch" type="xml">
            <pivot string="Audit Analytics">
                <field name="action_category" type="row"/>
                <field name="action" type="row"/>
                <field name="user_id" type="col"/>
            </pivot>
        </field>
    </record>
    
    <!-- Graph View for Trends -->
    <record id="view_admin_audit_graph" model="ir.ui.view">
        <field name="name">messob.fms.audit.log.graph</field>
        <field name="model">messob.fms.audit.log</field>
        <field name="arch" type="xml">
            <graph string="Audit Trends" type="line">
                <field name="timestamp" interval="day"/>
                <field name="action_category" type="col"/>
            </graph>
        </field>
    </record>
    
    <!-- Action Window -->
    <record id="action_admin_audit_logs" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">messob.fms.audit.log</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_admin_audit_search"/>
        <field name="context">{'search_default_filter_month': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_admin_audit_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_admin_audit_form')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_admin_audit_pivot')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_admin_audit_graph')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No audit logs yet.</p>
            <p>System actions will be recorded here automatically.</p>
            <p>All critical actions including logins, approvals, and data changes are tracked.</p>
        </field>
    </record>

    <!-- ================================================================
         6. PROFILE — opens current user's own partner form
    ================================================================ -->
    <record id="action_admin_profile" model="ir.actions.act_window">
        <field name="name">My Profile</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">form</field>
        <field name="res_id" eval="False"/>
        <field name="context">{'uid': uid}</field>
        <field name="target">current</field>
    </record>

</odoo>
