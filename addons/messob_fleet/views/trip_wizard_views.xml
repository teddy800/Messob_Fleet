<odoo>
    <record id="action_messob_trip_wizard" model="ir.actions.act_window">
        <field name="name">New Trip Request</field>
        <field name="res_model">messob.trip.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_messob_trip_wizard_form" model="ir.ui.view">
        <field name="name">messob.trip.wizard.form</field>
        <field name="model">messob.trip.wizard</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_previous" string="Previous" type="object" invisible="step == 1"/>
                    <button name="action_next" string="Next" type="object" class="btn-primary" invisible="step == 4"/>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="step != 4"/>
                    <button string="Cancel" special="cancel"/>
                </header>
                <notebook>
                    <page string="1. Trip Details" invisible="step != 1">
                        <group>
                            <field name="purpose"/>
                            <field name="category_id"/>
                        </group>
                    </page>
                    <page string="2. Schedule" invisible="step != 2">
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </page>
                    <page string="3. Locations" invisible="step != 3">
                        <group>
                            <field name="pickup_location"/>
                            <field name="destination_location"/>
                        </group>
                    </page>
                    <page string="4. Review &amp; Submit" invisible="step != 4">
                        <group string="Review">
                            <field name="purpose"/>
                            <field name="category_id"/>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="pickup_location"/>
                            <field name="destination_location"/>
                        </group>
                    </page>
                </notebook>
            </form>
        </field>
    </record>
</odoo>