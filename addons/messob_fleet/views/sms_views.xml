<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- SMS Log Tree View -->
    <record id="view_messob_fms_sms_log_tree" model="ir.ui.view">
        <field name="name">messob.fms.sms.log.tree</field>
        <field name="model">messob.fms.sms.log</field>
        <field name="arch" type="xml">
            <list string="SMS Logs" decoration-success="status=='sent'" decoration-danger="status=='failed'" decoration-warning="status=='pending'">
                <field name="create_date" string="Date"/>
                <field name="recipient_name"/>
                <field name="recipient_mobile"/>
                <field name="message"/>
                <field name="status" widget="badge" decoration-success="status=='sent'" decoration-danger="status=='failed'" decoration-warning="status=='pending'"/>
                <field name="provider"/>
                <field name="retry_count"/>
                <field name="cost" optional="hide"/>
                <field name="related_record" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- SMS Log Form View -->
    <record id="view_messob_fms_sms_log_form" model="ir.ui.view">
        <field name="name">messob.fms.sms.log.form</field>
        <field name="model">messob.fms.sms.log</field>
        <field name="arch" type="xml">
            <form string="SMS Log">
                <header>
                    <button name="action_retry_send" string="Retry Send" type="object" 
                            class="oe_highlight" invisible="status not in ['failed', 'retry']"/>
                    <field name="status" widget="statusbar" statusbar_visible="pending,sent,delivered"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    
                    <group>
                        <group string="Recipient">
                            <field name="recipient_name"/>
                            <field name="recipient_mobile"/>
                        </group>
                        <group string="Delivery">
                            <field name="sent_date"/>
                            <field name="delivered_date"/>
                            <field name="provider"/>
                            <field name="provider_message_id"/>
                        </group>
                    </group>
                    
                    <group string="Message">
                        <field name="message" nolabel="1"/>
                        <field name="message_length"/>
                    </group>
                    
                    <group string="Retry Information" invisible="status != 'failed'">
                        <field name="retry_count"/>
                        <field name="max_retries"/>
                        <field name="error_message"/>
                    </group>
                    
                    <group string="Cost Tracking" invisible="not cost">
                        <field name="cost"/>
                        <field name="currency_id"/>
                    </group>
                    
                    <group string="Related Record" invisible="not related_model">
                        <field name="related_model"/>
                        <field name="related_id"/>
                        <field name="related_record"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SMS Log Search View -->
    <record id="view_messob_fms_sms_log_search" model="ir.ui.view">
        <field name="name">messob.fms.sms.log.search</field>
        <field name="model">messob.fms.sms.log</field>
        <field name="arch" type="xml">
            <search string="SMS Logs">
                <field name="recipient_name"/>
                <field name="recipient_mobile"/>
                <field name="message"/>
                <field name="provider"/>
                <filter string="Pending" name="pending" domain="[('status', '=', 'pending')]"/>
                <filter string="Sent" name="sent" domain="[('status', '=', 'sent')]"/>
                <filter string="Failed" name="failed" domain="[('status', '=', 'failed')]"/>
                <filter string="Delivered" name="delivered" domain="[('status', '=', 'delivered')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[('create_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Month" name="this_month" domain="[('create_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by': 'provider'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- SMS Log Action -->
    <record id="action_messob_fms_sms_log" model="ir.actions.act_window">
        <field name="name">SMS Logs</field>
        <field name="res_model">messob.fms.sms.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_this_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No SMS logs yet
            </p>
            <p>
                SMS logs will appear here once notifications are sent.
            </p>
        </field>
    </record>

</odoo>
