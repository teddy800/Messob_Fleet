<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fuel Log Views -->
    <record id="view_fuel_log_tree" model="ir.ui.view">
        <field name="name">messob.fuel.log.tree</field>
        <field name="model">messob.fuel.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="volume"/>
                <field name="cost"/>
            </tree>
        </field>
    </record>

    <record id="view_fuel_log_form" model="ir.ui.view">
        <field name="name">messob.fuel.log.form</field>
        <field name="model">messob.fuel.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="driver_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="volume"/>
                            <field name="cost"/>
                            <field name="odometer"/>
                            <field name="station"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fuel_log" model="ir.actions.act_window">
        <field name="name">Fuel Logs</field>
        <field name="res_model">messob.fuel.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Maintenance Log Views -->
    <record id="view_maintenance_log_tree" model="ir.ui.view">
        <field name="name">messob.maintenance.log.tree</field>
        <field name="model">messob.maintenance.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="type"/>
                <field name="cost"/>
                <field name="next_due_date"/>
            </tree>
        </field>
    </record>

    <record id="view_maintenance_log_form" model="ir.ui.view">
        <field name="name">messob.maintenance.log.form</field>
        <field name="model">messob.maintenance.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="date"/>
                            <field name="type"/>
                            <field name="service_provider"/>
                        </group>
                        <group>
                            <field name="cost"/>
                            <field name="next_due_date"/>
                            <field name="next_due_odometer"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description Notes">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_maintenance_log" model="ir.actions.act_window">
        <field name="name">Maintenance Logs</field>
        <field name="res_model">messob.maintenance.log</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
